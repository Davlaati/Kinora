{
  "entities": {
    "User": {
      "title": "User",
      "description": "Kinora user profile synchronized with Telegram data.",
      "type": "object",
      "properties": {
        "telegram_id": { "type": "string", "description": "Unique Telegram User ID" },
        "first_name": { "type": "string" },
        "last_name": { "type": "string" },
        "username": { "type": "string" },
        "is_premium": { "type": "boolean", "description": "Subscription status" },
        "subscription_expiry": { "type": "string", "format": "date-time", "description": "ISO 8601 expiry date" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["telegram_id", "first_name", "is_premium"]
    },
    "Movie": {
      "title": "Movie",
      "description": "Movie metadata and streaming links.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "genre": { "type": "string" },
        "poster_url": { "type": "string" },
        "video_url": { "type": "string", "description": "HLS stream link or Telegram file ID" },
        "is_premium": { "type": "boolean" },
        "duration": { "type": "string" },
        "release_year": { "type": "number" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "video_url", "is_premium"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/movies/{movieId}": {
      "schema": "Movie",
      "description": "Movie catalog"
    }
  }
}
